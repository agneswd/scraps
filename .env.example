# PocketBase admin credentials (required for the notifier sidecar)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=

# VAPID keys for Web Push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Gemini AI (free tier, 500 req/day global — 100 req/day per-household default)
VITE_GEMINI_KEY=

# Spoonacular (free tier, 150 req/day — reserved for future use)
VITE_SPOONACULAR_KEY=

# Cloudflare Tunnel token (only needed with --profile tunnel)
TUNNEL_TOKEN=
